# Puerto del servidor
PORT=5000

# MongoDB (Atlas o local)
# Ejemplo Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://usuario:password@cluster.xxxxx.mongodb.net/perennialpark?retryWrites=true&w=majority

# Entorno (development | production | test)
NODE_ENV=development

# ========== Firebase (login y verificación de token) ==========
# Usar archivo JSON evita "Invalid PEM formatted message" con la clave en .env
# Descargar desde Firebase Console > Proyecto > Configuración > Cuentas de servicio
GOOGLE_APPLICATION_CREDENTIALS=./perennialpark-firebase-adminsdk-xxxxx.json

# Opción B: Variables individuales (puede dar error de PEM en .env)
# FIREBASE_STORAGE_BUCKET=perennialpark.firebasestorage.app
# FIREBASE_PROJECT_ID=perennialpark
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@perennialpark.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# API Key web de Firebase (Proyecto > Configuración > General > Claves API)
# Requerida para login con email/password - obtener en Firebase Console
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here

# ========== Nodemailer (Gmail - envío de correos) ==========
# Cuenta Gmail desde la que se envían los correos
MAIL_USER=perennialparkdev@gmail.com

# Contraseña de aplicación de 16 caracteres (NO la contraseña normal de Gmail).
# Crear en: Cuenta Google > Seguridad > Verificación en 2 pasos > Contraseñas de aplicaciones
MAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Destinatario para envío de prueba (ej. correo de prueba o notificaciones)
MAIL_TEST_TO=manuelchaparro94@gmail.com

# ========== Roles (opcional) ==========
# ID del rol Administrador para verify-role
# ADMIN_ROL_ID=
